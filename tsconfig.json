{
  "compilerOptions": {
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "paths": {
      "#app": [".nuxt"],
      "#app/*": [".nuxt/*"],
      "#build": [".nuxt"],
      "#build/*": [".nuxt/*"]
    }
  },
  "include": [
    ".nuxt/tsconfig.json"
  ]
}
